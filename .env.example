# PayPal Configuration
# Obtén tu Client ID en: https://developer.paypal.com/dashboard/
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# WhatsApp Configuration
# Número en formato internacional sin el símbolo +
# Ejemplo: 51987654321 (para Perú)
NEXT_PUBLIC_WHATSAPP_NUMBER=51987654321

# Payload Configuration
# Utiliza estas variables en tu entorno de desarrollo
PAYLOAD_SECRET=your-strong-secret-here
DATABASE_URI=postgres://user:password@localhost:5432/dbname
